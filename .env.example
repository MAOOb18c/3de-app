# Server-side secrets. Do not expose these values in frontend code.
OPENAI_API_KEY=
X_BEARER_TOKEN=
X_API_KEY=

# Server settings.
PORT=3001
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# Frontend public settings. Values prefixed with VITE_ are bundled into the client.
VITE_API_BASE_URL=http://localhost:3001
VITE_PUBLIC_PREVIEW=false
